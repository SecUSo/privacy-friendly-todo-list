    <string name="help_overview_heading">Información general</string>
    <string name="help_intro">Esta aplicación se puede utilizar para recordar las tareas pendientes y para organizar una agenda personal.</string>
    <string name="help_group_lists">Administración</string>
    <string name="help_todo_lists_title">Listas de tareas</string>
    <string name="help_todo_lists">Una lista de tareas es un grupo de tareas y se la puede crear usando el botón + en el menu Inicio. Las tareas dentro de una lista de tareas se las puede marcar para diferenciar las tareas cumplidas de las no cumplidas.</string>
    <string name="help_subtasks_title">Subtareas</string>
    <string name="help_subtasks">Las subtareas representan las etapas por las que hay que pasar para cumplir una tarea. Se las puede crear haciendo clic en una tarea dentro de una lista de tareas.</string>
    <string name="help_deadline_reminder_title">Fechas límites y recordatorios</string>
    <string name="help_deadline_reminder">Las fechas límites y las alarmas se las puede crear solo para las tareas. Puedes introducirlas cuando creas una tarea nueva o editándola.</string>
    <string name="help_group_app">Ajustes</string>
    <string name="help_pin_title">Ajustes</string>
    <string name="help_pin">Abre el menú de ajustes para configurar la protección mediante PIN. El PIN debe tener al menos 4 dígitos. Se te pedirá cada vez que inicies la aplicación.</string>
    <string name="help_group_privacy">Información sobre la privacidad</string>
    <string name="help_permission_receive_boot_completed">RECEIVE_BOOT_COMPLETED: Esto permite comprobar si el usuario desea enterarse de las próximas fechas límite justo después de haber puesto en marcha el dispositivo.</string>
